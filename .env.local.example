# 세션 시크릿 (아무 랜덤 문자열)
SESSION_SECRET=your-random-secret-string

# 관리자 계정
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=your-password

# AWS 공통 (DynamoDB + S3 공용)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# AWS DynamoDB 테이블 이름
DYNAMODB_POSTS_TABLE=ai-lab-notes-posts
DYNAMODB_PROJECTS_TABLE=ai-lab-notes-projects

# AWS S3 이미지 저장소
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PUBLIC_URL=https://your-bucket.s3.ap-northeast-2.amazonaws.com

# On-Demand ISR (선택)
REVALIDATE_SECRET=your-revalidate-secret
