---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

function formatDate(date: Date) {
  return date.toLocaleDateString('ko-KR', {
    year:  'numeric',
    month: 'long',
    day:   'numeric',
  });
}

const BASE = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <article class="max-w-2xl mx-auto px-6 py-14">

    <!-- Breadcrumb -->
    <div class="text-sm text-[#b0977a] mb-8">
      <a href={`${BASE}/blog/`} class="hover:text-[#c07a2f] transition-colors">Blog</a>
      <span class="mx-2">›</span>
      <span class="text-[#7a6a52]">{title}</span>
    </div>

    <!-- Header -->
    <header class="mb-10 pb-10 border-b border-[#e8ddd0]">
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => (
          <span class="text-xs font-medium text-[#c07a2f] bg-[#fdf3e3] px-2.5 py-1 rounded-full">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="font-serif text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-[#1a1208] mb-4">
        {title}
      </h1>
      <p class="text-[#7a6a52] text-base leading-relaxed mb-5">{description}</p>
      <div class="text-sm text-[#b0977a] flex items-center gap-3">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && (
          <>
            <span>·</span>
            <span>수정: <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time></span>
          </>
        )}
      </div>
    </header>

    <!-- Body -->
    <div class="prose prose-warm prose-lg max-w-none
                prose-headings:font-serif prose-headings:font-bold prose-headings:tracking-tight
                prose-a:text-[#c07a2f] prose-a:no-underline hover:prose-a:underline
                prose-code:text-[#c07a2f] prose-code:bg-[#fdf3e3] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                prose-code:before:content-none prose-code:after:content-none
                prose-pre:rounded-xl prose-pre:overflow-x-auto prose-pre:shadow-md
                prose-blockquote:border-[#d4b896] prose-blockquote:text-[#7a6a52]
                prose-hr:border-[#e8ddd0]">
      <slot />
    </div>

  </article>
</BaseLayout>

<style>
  /* pre 안의 code 태그에 인라인 코드 스타일이 적용되는 것을 방지 */
  .prose pre code {
    background: transparent;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }
</style>
