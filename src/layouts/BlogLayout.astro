---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

function formatDate(date: Date) {
  return date.toLocaleDateString('ko-KR', {
    year:  'numeric',
    month: 'long',
    day:   'numeric',
  });
}

const BASE = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <article class="max-w-2xl mx-auto px-6 py-14">

    <!-- Breadcrumb -->
    <div class="text-sm text-[#b0977a] mb-8">
      <a href={`${BASE}/blog/`} class="hover:text-[#c07a2f] transition-colors">Blog</a>
      <span class="mx-2">›</span>
      <span class="text-[#7a6a52]">{title}</span>
    </div>

    <!-- Header -->
    <header class="mb-10 pb-10 border-b border-[#e8ddd0]">
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => (
          <span class="text-xs font-medium text-[#c07a2f] bg-[#fdf3e3] px-2.5 py-1 rounded-full">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="font-serif text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-[#1a1208] mb-4">
        {title}
      </h1>
      <p class="text-[#7a6a52] text-base leading-relaxed mb-5">{description}</p>
      <div class="text-sm text-[#b0977a] flex items-center gap-3">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && (
          <>
            <span>·</span>
            <span>수정: <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time></span>
          </>
        )}
      </div>
    </header>

    <!-- Body -->
    <div class="prose prose-warm max-w-none
                prose-headings:font-serif prose-headings:font-bold prose-headings:tracking-tight
                prose-a:text-[#c07a2f] prose-a:no-underline hover:prose-a:underline
                prose-code:text-[#c07a2f] prose-code:before:content-none prose-code:after:content-none
                prose-pre:rounded-lg prose-pre:overflow-x-auto
                prose-blockquote:border-[#d4b896] prose-blockquote:text-[#7a6a52]
                prose-hr:border-[#e8ddd0]">
      <slot />
    </div>

  </article>
</BaseLayout>

<style is:global>
  /* 전체 줄 간격 축소 */
  .prose {
    line-height: 1.7;
    font-size: 0.975rem;
  }

  /* 단락 간격 축소 */
  .prose p {
    margin-top: 0.75em !important;
    margin-bottom: 0.75em !important;
  }

  /* 목록 간격 — 줄 간격만, 마진 없음 */
  .prose ul,
  .prose ol {
    margin-top: 0.5em !important;
    margin-bottom: 0.5em !important;
  }

  .prose li {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  .prose li > p {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }

  /* 제목 간격 축소 */
  .prose h2,
  .prose h3,
  .prose h4 {
    margin-top: 1.4em !important;
    margin-bottom: 0.4em !important;
  }

  /* 코드 블록 디자인 — 라이트 테마, 거의 투명한 배경 */
  .prose pre {
    background-color: rgba(0, 0, 0, 0.04) !important;
    border: 1px solid #e0d8cc;
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    line-height: 1.55;
    font-size: 0.875rem;
    font-family: 'Consolas', 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
  }

  /* pre 안의 code 태그에 인라인 코드 스타일이 새어나오는 것을 방지 */
  .prose pre code {
    background: transparent;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
    font-family: inherit;
  }
</style>
