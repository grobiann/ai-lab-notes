---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const BASE = import.meta.env.BASE_URL;

const {
  title,
  description = 'AI · 개발 · 학습을 기록하는 grobiann의 블로그',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const navLinks = [
  { href: `${BASE}/blog/`,     label: 'Blog' },
  { href: `${BASE}/projects/`, label: 'Projects' },
  { href: `${BASE}/about/`,    label: 'About' },
];
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ko" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
  <title>{title} · grobiann</title>
</head>
<body class="bg-[#faf8f5] text-[#2c2416] font-sans antialiased min-h-screen flex flex-col">

  <!-- NAV -->
  <header class="sticky top-0 z-50 bg-[#faf8f5]/90 backdrop-blur border-b border-[#e8ddd0]">
    <nav class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href={`${BASE}/`} class="font-serif text-lg font-bold tracking-tight text-[#2c2416] hover:text-[#c07a2f] transition-colors">
        grobiann<em class="not-italic text-[#c07a2f]">.</em>
      </a>
      <ul class="flex items-center gap-1">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`text-sm px-3 py-1.5 rounded-md transition-colors ${
                currentPath.startsWith(href)
                  ? 'text-[#c07a2f] font-medium bg-[#fdf3e3]'
                  : 'text-[#7a6a52] hover:text-[#2c2416] hover:bg-[#f5ead8]'
              }`}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </header>

  <!-- CONTENT -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="border-t border-[#e8ddd0] mt-16">
    <div class="max-w-3xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-[#b0977a]">
      <span>© {new Date().getFullYear()} grobiann</span>
      <div class="flex items-center gap-4">
        <span>Built with <a href="https://astro.build" class="hover:text-[#c07a2f] transition-colors">Astro</a> · Hosted on GitHub Pages</span>
        <a href={`${BASE}/admin/`} class="text-[#d4b896] hover:text-[#c07a2f] transition-colors">Admin</a>
      </div>
    </div>
  </footer>

</body>
</html>
