---
import BaseLayout from '../layouts/BaseLayout.astro';

const BASE = import.meta.env.BASE_URL;

const techStack = [
  { category: '메인 기술', items: ['Unity', 'C#', 'Android', 'iOS'] },
  { category: '클라우드', items: ['Firebase', 'AWS Cognito', 'DynamoDB', 'S3', 'Kinesis Firehose', 'Lambda', 'Athena', 'Glue'] },
  { category: '도구', items: ['Jenkins', 'Spine', 'Winform', 'AppsScript'] },
  { category: '협업', items: ['Git', 'Slack', 'Asana'] },
];

const experiences = [
  {
    company: '네오위즈',
    period: '2023.05 — 재직중',
    role: 'Game Client Developer',
    projects: [
      {
        title: '고고레이더스',
        period: '2024.01 — 2024.08 · 8개월',
        desc: '모바일 뱀서라이크 출시 (3인 개발)',
        items: [
          '게임 내 모든 컨텐츠를 기획 단계부터 개발',
          'Grid 기반 맵 데이터를 활용해 스테이지별 리소스 동적 적용',
          '스킬 시스템 데이터 구조 개선, 모델 의존성 제거 및 툴 개발',
          '밸런스 데이터 적용 자동화',
        ],
        tags: ['Unity', 'C#', 'Android', 'iOS', 'Jenkins', 'Firebase'],
      },
      {
        title: 'LoopBound',
        period: '2023.05 — 2023.12 · 8개월',
        desc: '모바일 로그라이트 RPG 출시 (7인 개발)',
        items: [
          '인게임 신규 컨텐츠와 아웃게임 시스템 전체 개발',
          '빌드 및 Jenkins 관리, Jenkins 템플릿 제작',
          '기획·아트 작업자 Unity 활용 지원 및 교육 → 팀 전체 역량 향상',
        ],
        tags: ['Unity', 'C#', 'Jenkins'],
      },
    ],
  },
  {
    company: '테서랙트 스튜디오',
    period: '2020.09 — 2022.07',
    role: 'Game Client Developer & PM',
    note: '기획·아트·프로그래머 3인 공동 창업 스타트업',
    projects: [
      {
        title: '헌터서바이벌',
        period: '2022.03 — 2022.07 · 5개월',
        desc: '모바일 핵앤슬래시 인기순위 1위 출시 및 운영',
        items: [
          '게임 내 모든 컨텐츠를 기획 단계부터 개발, 출시 및 운영',
          '외부 서버 플랫폼 → AWS 전환으로 서버 비용 절감 (매출의 7% → 0%)',
          'Job 시스템(멀티 쓰레딩) 도입으로 게임 속도 100% 향상 (20fps → 40fps)',
          'iOS 출시를 위해 Google Cloud → AWS DynamoDB 데이터 이전',
        ],
        tags: ['Unity', 'C#', 'Android', 'Spine', 'AWS'],
      },
      {
        title: '미니알피지: 판옵티콘',
        period: '2020.09 — 2022.02 · 1년 6개월',
        desc: '모바일 RPG 출시 및 운영',
        items: [
          '스타트업 게임 구성에 필요한 모든 IT 기능 기반 마련',
          'XML 기반 게임 데이터 구축으로 기획자 업무 안정화 (데이터 오류 0건)',
          '130여 개 게임 맵을 생성·수정하는 맵툴 직접 제작',
        ],
        tags: ['Unity', 'C#', 'Android', 'iOS'],
      },
    ],
  },
  {
    company: '키글',
    period: '2019.05 — 2020.04',
    role: 'Game Client Developer',
    projects: [
      {
        title: '로보카폴리 지진안전',
        period: '2019.05 — 2020.04 · 1년',
        desc: '모바일 키즈 앱 출시 (유튜브 조회수 4,000만)',
        items: [
          '앱 내 15개 게임 개발',
          '게임 유형별 템플릿 제작으로 개발 속도 향상 (2~3일 → 6시간)',
          '뽀로로 간식놀이, 뽀로로와 동물친구들 Android/iOS 출시 (각 10만·5만 다운로드)',
        ],
        tags: ['Unity', 'C#', 'Android', 'iOS', 'Spine'],
      },
    ],
  },
];
---

<BaseLayout title="About" description="장진석 — 다수의 출시 경험을 가진 5년차 클라이언트 개발자">

  <div class="max-w-2xl mx-auto px-6 py-14">

    <!-- Intro -->
    <section class="mb-14 pb-12 border-b border-[#e8ddd0]">
      <p class="text-xs font-semibold tracking-widest uppercase text-[#c07a2f] mb-4">About</p>
      <h1 class="font-serif text-4xl font-bold tracking-tight text-[#1a1208] mb-1">장진석</h1>
      <p class="text-[#7a6a52] text-base mb-6">5년차 클라이언트 개발자 · 다수의 출시 경험</p>
      <div class="space-y-4 text-[#7a6a52] text-base leading-relaxed mb-8">
        <p>
          주로 <strong class="text-[#2c2416] font-semibold">협업 프로세스와 팀 문화</strong>에 관심이 있습니다.
          사촌 형과 스타트업(테서랙트스튜디오)을 공동 창업하며 협업의 기반을 마련하는 데 힘썼습니다.
          Slack, Asana, Git 사용 방식을 정립하고, 기획·아트 산출물을 Unity에 원활하게 적용하는 규칙을 세워
          많은 리소스에도 충돌 없이 게임 2개를 안정적으로 출시했습니다.
        </p>
        <p>
          <strong class="text-[#2c2416] font-semibold">코드 품질</strong>을 중요하게 생각합니다.
          다른 작업자가 읽었을 때 쉽게 이해할 수 있도록 변수·함수 네이밍과 구조 설계에 공을 들입니다.
          최근에는 특히 코드 재사용성에 관심을 갖고 고민하고 있습니다.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href="https://github.com/grobiann"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-[#2c2416] bg-[#f5ead8] hover:bg-[#ecdcc0] border border-[#d4b896] px-4 py-2 rounded-lg transition-colors"
        >
          GitHub →
        </a>
        <a
          href="mailto:grobiann0@gmail.com"
          class="inline-flex items-center gap-2 text-sm font-medium text-[#2c2416] bg-[#f5ead8] hover:bg-[#ecdcc0] border border-[#d4b896] px-4 py-2 rounded-lg transition-colors"
        >
          grobiann0@gmail.com
        </a>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="mb-14 pb-12 border-b border-[#e8ddd0]">
      <h2 class="font-serif text-2xl font-bold tracking-tight text-[#1a1208] mb-7">기술 스택</h2>
      <div class="space-y-5">
        {techStack.map(({ category, items }) => (
          <div class="flex gap-4 sm:gap-8">
            <span class="text-sm font-semibold text-[#b0977a] w-24 flex-shrink-0 pt-0.5">
              {category}
            </span>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="text-sm text-[#2c2416] bg-white border border-[#e8ddd0] px-3 py-1 rounded-lg">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Work Experience -->
    <section class="mb-14 pb-12 border-b border-[#e8ddd0]">
      <h2 class="font-serif text-2xl font-bold tracking-tight text-[#1a1208] mb-8">경력</h2>
      <div class="space-y-10">
        {experiences.map(({ company, period, role, note, projects }) => (
          <div>
            <!-- Company Header -->
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
              <h3 class="font-semibold text-[#1a1208] text-lg">{company}</h3>
              <span class="text-sm text-[#b0977a]">{period}</span>
            </div>
            <p class="text-sm text-[#c07a2f] font-medium mb-1">{role}</p>
            {note && (
              <p class="text-xs text-[#b0977a] mb-4">{note}</p>
            )}
            <!-- Projects -->
            <div class="space-y-4 mt-4">
              {projects.map(({ title, period: pPeriod, desc, items, tags }) => (
                <div class="bg-white border border-[#e8ddd0] rounded-xl p-5">
                  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
                    <span class="font-semibold text-[#2c2416]">{title}</span>
                    <span class="text-xs text-[#b0977a]">{pPeriod}</span>
                  </div>
                  <p class="text-sm text-[#7a6a52] mb-3">{desc}</p>
                  <ul class="space-y-1 mb-3">
                    {items.map((item) => (
                      <li class="flex gap-2 text-sm text-[#7a6a52]">
                        <span class="text-[#d4b896] mt-0.5 flex-shrink-0">›</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="flex flex-wrap gap-1.5">
                    {tags.map((tag) => (
                      <span class="text-xs text-[#7a6a52] bg-[#f5ead8] border border-[#e8ddd0] px-2.5 py-0.5 rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section class="mb-14 pb-12 border-b border-[#e8ddd0]">
      <h2 class="font-serif text-2xl font-bold tracking-tight text-[#1a1208] mb-6">학력</h2>
      <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
        <div>
          <p class="font-semibold text-[#2c2416]">충남대학교</p>
          <p class="text-sm text-[#7a6a52]">자연과학계열 수학과 · 졸업</p>
        </div>
        <span class="text-sm text-[#b0977a]">2011.03 — 2017.08</span>
      </div>
    </section>

    <!-- This Site -->
    <section>
      <h2 class="font-serif text-2xl font-bold tracking-tight text-[#1a1208] mb-5">이 사이트는</h2>
      <ul class="space-y-2 text-[#7a6a52] text-sm leading-relaxed">
        <li class="flex gap-3">
          <span class="text-[#d4b896] mt-1">›</span>
          <span><strong class="text-[#2c2416]">Astro</strong>로 빌드 — 최소한의 JavaScript, 빠른 로딩</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[#d4b896] mt-1">›</span>
          <span><strong class="text-[#2c2416]">Tailwind CSS</strong>로 스타일링</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[#d4b896] mt-1">›</span>
          <span><strong class="text-[#2c2416]">GitHub Pages</strong>로 무료 호스팅</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[#d4b896] mt-1">›</span>
          <span><strong class="text-[#2c2416]">GitHub Actions</strong>으로 자동 배포</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[#d4b896] mt-1">›</span>
          <span>소스코드:
            <a
              href="https://github.com/grobiann/ai-lab-notes"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#c07a2f] hover:underline"
            >
              github.com/grobiann/ai-lab-notes
            </a>
          </span>
        </li>
      </ul>
    </section>

  </div>

</BaseLayout>
