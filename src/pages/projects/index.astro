---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects" description="grobiann의 프로젝트 포트폴리오">

  <div class="max-w-3xl mx-auto px-6 py-14">

    <header class="mb-12">
      <p class="text-xs font-semibold tracking-widest uppercase text-[#c07a2f] mb-3">Projects</p>
      <h1 class="font-serif text-4xl font-bold tracking-tight text-[#1a1208] mb-3">프로젝트</h1>
      <p class="text-[#7a6a52]">직접 만들고 기여한 것들</p>
    </header>

    {projects.length === 0 ? (
      <p class="text-[#b0977a]">아직 등록된 프로젝트가 없습니다.</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {projects.map((project) => (
          <a
            href={`${BASE}/projects/${project.slug}/`}
            class="group block bg-white border border-[#e8ddd0] hover:border-[#d4b896] rounded-xl p-6 transition-all hover:shadow-md"
          >
            <h2 class="font-serif text-lg font-bold text-[#2c2416] group-hover:text-[#c07a2f] transition-colors mb-2 leading-snug">
              {project.data.title}
            </h2>
            <p class="text-sm text-[#7a6a52] leading-relaxed mb-5 line-clamp-3">
              {project.data.description}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {project.data.tags.map((tag) => (
                <span class="text-xs text-[#7a6a52] bg-[#f5ead8] border border-[#e8ddd0] px-2.5 py-0.5 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
            {(project.data.github || project.data.demo) && (
              <div class="mt-5 pt-4 border-t border-[#f5ead8] flex gap-3 text-xs text-[#b0977a]">
                {project.data.github && <span>GitHub ↗</span>}
                {project.data.demo && <span>Demo ↗</span>}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </div>

</BaseLayout>
